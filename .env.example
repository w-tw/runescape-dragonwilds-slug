# === STEAM LOGIN (required) ===
# A Steam account that owns RuneScape: Dragonwilds.
# Anonymous login does NOT work for this app.
# NOTE: If your account uses Steam Guard, see README for first-run instructions.
STEAM_USER=
STEAM_PASS=

# === SERVER CONFIG (required) ===

# Your RuneScape: Dragonwilds Player ID.
# Found in-game: Settings menu > bottom of page. Use the copy button.
OWNER_ID=

# The name of your server (visible in the public server list).
SERVER_NAME=

# === OPTIONAL ===

# Name for the default world created on first startup.
# Defaults to SERVER_NAME if not set.
DEFAULT_WORLD_NAME=

# Admin password for the Server Management tab (in-game pause menu > settings).
# Anyone who enters this password becomes an admin until it's changed.
ADMIN_PASSWORD=changeme

# World password. Leave empty for a public server.
WORLD_PASSWORD=
