# === SERVER CONFIG (required) ===

# Your RuneScape: Dragonwilds Player ID.
# Found in-game: Settings menu > bottom of page. Use the copy button.
OWNER_ID=

# The name of your server (visible in the public server list).
SERVER_NAME=DragonWildsServer

# Password to access Server Management tab (in-game pause menu > settings).
# Anyone who enters this password becomes an admin until it's changed.
ADMIN_PASSWORD=changeme

# === OPTIONAL ===

# Name for the default world created on first startup.
DEFAULT_WORLD_NAME=MyWorld

# World password. Leave empty for a public server.
WORLD_PASSWORD=

# UDP port the server listens on.
DEFAULT_PORT=7777

# Maximum number of players (2GB base + 1GB per player).
MAX_PLAYERS=6

# Set to false to skip downloading/validating server files on startup.
UPDATE_ON_START=true
